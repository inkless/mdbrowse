{
  "name": "@inkless/mdbrowse",
  "version": "0.2.5",
  "description": "Browse a folder of Markdown locally as a GitHub-styled site. Sidebar nav, ⌘K file search, live reload, mermaid + math, shiki dual-theme highlighting, programmatic API — fully offline, no GitHub API calls.",
  "keywords": [
    "markdown",
    "grip",
    "github",
    "preview",
    "viewer",
    "cli",
    "readme",
    "mermaid",
    "shiki",
    "live-reload"
  ],
  "license": "MIT",
  "author": "Guangda Zhang",
  "homepage": "https://github.com/inkless/mdbrowse#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inkless/mdbrowse.git"
  },
  "bugs": {
    "url": "https://github.com/inkless/mdbrowse/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "mdbrowse": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "pnpm build && playwright test",
    "test:e2e:ui": "pnpm build && playwright test --ui",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "prepublishOnly": "pnpm build && pnpm test && pnpm lint"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@playwright/test": "^1.59.1",
    "@types/markdown-it": "^14.1.2",
    "@types/markdown-it-emoji": "^3.0.1",
    "@types/markdown-it-footnote": "^3.0.4",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "husky": "^9.1.7",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "markdown-it": "^14.1.1",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-mathjax3": "^5.2.0",
    "markdown-it-task-lists": "^2.1.1",
    "mime-types": "^3.0.2",
    "open": "^11.0.0",
    "shiki": "^4.0.2",
    "ws": "^8.20.0"
  }
}
